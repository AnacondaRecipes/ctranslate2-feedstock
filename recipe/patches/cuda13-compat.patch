Fix CUDA 13 (CCCL 2.8+) compatibility: cub::FpLimits and thrust::identity removed.

cub::FpLimits was removed in CCCL 2.8+ (CUDA 13). Use version-guarded
macro CT2_FP_LOWEST(T) with cuda::std::numeric_limits for CUDA 13+,
keeping cub::FpLimits for CUDA 12.

thrust::identity<T> was removed in CCCL 2.8+. Provide a simple
identity functor that works across all CUDA versions.

--- a/src/ops/dequantize_gpu.cu
+++ b/src/ops/dequantize_gpu.cu
@@ -2,6 +2,15 @@
 
 #include "cuda/helpers.h"
 
+// thrust::identity<T> was removed in CCCL 2.8+ (CUDA 13).
+// Provide a simple replacement that works across all CUDA versions.
+namespace ctranslate2 {
+  template <typename T>
+  struct identity_func {
+    __device__ __forceinline__ T operator()(const T& x) const { return x; }
+  };
+}
+
 namespace ctranslate2 {
   namespace ops {
 
